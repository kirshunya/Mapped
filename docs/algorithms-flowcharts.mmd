%% Algorithm 1: User Registration and Authentication with JWT
%% ========================================================

graph TD
    Start1([User Initiates Registration]) --> Input1[Enter Email, Username, Password]
    Input1 --> Validate1{Email format valid?}
    Validate1 -->|No| Error1[Return Validation Error]
    Error1 --> End1([Registration Failed])
    
    Validate1 -->|Yes| Validate2{Username length 3-30?}
    Validate2 -->|No| Error1
    
    Validate2 -->|Yes| Validate3{Password length >= 6?}
    Validate3 -->|No| Error1
    
    Validate3 -->|Yes| CheckEmail[Query DB: SELECT User WHERE email]
    CheckEmail --> EmailExists{Email already exists?}
    EmailExists -->|Yes| Error2[Return: Email Already Registered]
    Error2 --> End1
    
    EmailExists -->|No| HashPassword["Hash Password: bcrypt.GenerateFromPassword"]
    HashPassword --> InsertDB["INSERT User(email, username, hashedPassword, role='user')"]
    InsertDB --> GenerateJWT["Generate JWT Token: jwt.SignedString"]
    GenerateJWT --> BuildResp["Build AuthResponse: token + user data"]
    BuildResp --> Return1["Return 201 Created + Token"]
    Return1 --> Success1([Registration Success])

    %% Algorithm 2: Login with JWT Validation
    %% ====================================
    
graph TD
    Start2([User Initiates Login]) --> Input2[Enter Email and Password]
    Input2 --> QueryUser["Query DB: SELECT User WHERE email"]
    QueryUser --> UserFound{User exists?}
    UserFound -->|No| Error3[Return: User Not Found]
    Error3 --> End2([Login Failed])
    
    UserFound -->|Yes| ComparePass["Compare Password: bcrypt.CompareHashAndPassword"]
    ComparePass --> PassMatch{Passwords match?}
    PassMatch -->|No| Error4[Return: Invalid Password]
    Error4 --> End2
    
    PassMatch -->|Yes| GenerateJWT2["Generate JWT Token: jwt.SignedString"]
    GenerateJWT2 --> UpdateLastLogin["UPDATE User SET last_login = NOW()"]
    UpdateLastLogin --> BuildResp2["Build AuthResponse: token + user data"]
    BuildResp2 --> Return2["Return 200 OK + Token"]
    Return2 --> Success2([Login Success])

    %% Algorithm 3: Geo-Search - Find Nearby Places
    %% ==========================================

graph TD
    Start3([User Initiates Geo-Search]) --> GetCoords[Get GPS Coordinates: lat, lng, radius]
    GetCoords --> QueryPlace["Query DB: SELECT Place WHERE ST_Distance(point, user_location) <= radius"]
    QueryPlace --> Filter["Filter by: privacy = public, approval = approved"]
    Filter --> SortRating["Sort by Rating DESC"]
    SortRating --> Limit["LIMIT 20"]
    Limit --> GetCount["Get total count for pagination"]
    GetCount --> BuildResp3["Build PlaceResponse[]"]
    BuildResp3 --> Return3["Return 200 OK + places[]"]
    Return3 --> Success3([Geo-Search Complete])

    %% Algorithm 4: Create Post with Media Upload
    %% ========================================

graph TD
    Start4([User Creates Post]) --> SelectMedia["Select Media Files"]
    SelectMedia --> Upload["Upload to File Storage"]
    Upload --> SaveMedia["FOR EACH file: SaveMediaFile to DB"]
    SaveMedia --> GetURLs["Collect Media URLs[]"]
    GetURLs --> ValidatePost{Content not empty?}
    ValidatePost -->|No| Error5[Return: Content Required]
    Error5 --> End4([Post Creation Failed])
    
    ValidatePost -->|Yes| InsertPost["INSERT Post(userID, content, mediaURLs, placeID)"]
    InsertPost --> UpdatePlace["IF placeID: UPDATE Place SET like_count + 1"]
    UpdatePlace --> IncrementFeed["Add to User Feed Cache"]
    IncrementFeed --> BuildResp4["Build PostResponse"]
    BuildResp4 --> Notify["Notify followers via WebSocket"]
    Notify --> Return4["Return 201 Created"]
    Return4 --> Success4([Post Created])

    %% Algorithm 5: Calculate Place Rating
    %% ==================================

graph TD
    Start5([Review Submitted]) --> InsertRev["INSERT Review(placeID, rating, userID)"]
    InsertRev --> QueryReviews["SELECT ALL Review WHERE placeID = ?"]
    QueryReviews --> CalcAvg["CALCULATE: avg(rating) FROM reviews"]
    CalcAvg --> CalcCount["COUNT total reviews"]
    CalcCount --> UpdatePlace2["UPDATE Place SET rating = avg, review_count = COUNT"]
    UpdatePlace2 --> UpdateStats["Update place stats in cache"]
    UpdateStats --> Return5["Return 201 Created"]
    Return5 --> Success5([Rating Updated])

    %% Algorithm 6: Follow/Unfollow User with Notification
    %% =================================================

graph TD
    Start6([User Follows Another]) --> CheckFollow["Query DB: SELECT Follow WHERE followerID = ? AND followeeID = ?"]
    CheckFollow --> Exists{Already following?}
    Exists -->|Yes| Error6[Return: Already Following]
    Error6 --> End6([Follow Failed])
    
    Exists -->|No| InsertFollow["INSERT Follow(followerID, followeeID)"]
    InsertFollow --> IncrementFollower["UPDATE User SET followerCount + 1 WHERE id = followeeID"]
    IncrementFollower --> SendNotif["Send Notification: 'User X started following you'"]
    SendNotif --> PushWS["PUSH notification via WebSocket"]
    PushWS --> CacheUpdate["Update follower cache"]
    CacheUpdate --> Return6["Return 201 Created"]
    Return6 --> Success6([Follow Success])
