' AUTH SERVICE (7 классов)
' ══════════════════════════════════════════
package "auth-service" #1F1F2E {
    enum Role {
        user
        moderator
        admin
    }

    class User <<Entity>> {
        + ID : uint <<PK>>
        + Email : string <<unique>>
        + Username : string <<unique>>
        - Password : string
        + Role : Role
        + Avatar : string
        + Bio : string
        + IsActive : bool
        + CreatedAt : time.Time
        + UpdatedAt : time.Time
        - DeletedAt : gorm.DeletedAt
    }

    class AuthService <<Service>> {
        - repo : AuthRepository
        - jwtSecret : string
        - jwtExpiry : time.Duration
        __
        + Register(req : RegisterRequest) : AuthResponse
        + Login(req : LoginRequest) : AuthResponse
        + GetUserByID(id : uint) : User
        + GetAllUsers() : []User
        + UpdateUser(userID : uint, req : UpdateUserRequest) : User
        + ChangeRole(adminID : uint, req : ChangeRoleRequest) : error
        + SearchUsers(query : string, limit : int, excludeID : uint) : []User
        + ValidateToken(tokenString : string) : (uint, string, error)
        - generateToken(userID : uint, role : string) : string
    }

    class AuthRepository <<Repository>> {
        - db : gorm.DB
        __
        + CreateUser(user : User) : error
        + GetUserByEmail(email : string) : User
        + GetUserByID(id : uint) : User
        + GetAllUsers() : []User
        + UpdateUser(user : User) : error
        + UpdateRole(userID : uint, role : Role) : error
        + DeleteUser(id : uint) : error
        + SearchUsers(query : string, limit : int, excludeID : uint) : []User
    }

    class RegisterRequest <<DTO Request>> {
        + Email : string
        + Username : string
        + Password : string
    }

    class LoginRequest <<DTO Request>> {
        + Email : string
        + Password : string
    }

    class AuthResponse <<DTO Response>> {
        + Token : string
        + User : User
    }
}

